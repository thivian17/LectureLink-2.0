# ============================================================
# LectureLink v2 — Environment Variables
# Copy this file to .env (backend) and packages/web/.env.local (frontend)
# ============================================================

# ----------------------------------------------------------
# Backend (packages/api) — Required
# ----------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# ----------------------------------------------------------
# Backend (packages/api) — Optional (have defaults)
# ----------------------------------------------------------
# SUPABASE_SERVICE_KEY=          # Default: "" — needed for admin/RLS-bypass operations
# GOOGLE_API_KEY=                # Default: "" — needed for Gemini LLM (syllabus extraction, quizzes, coach)
# GOOGLE_CLOUD_PROJECT=          # Default: "" — GCP project ID if using Vertex AI
# ENVIRONMENT=development        # Default: "development" — set to "production" in prod
# DATABASE_URL=                  # Default: "" — direct Postgres connection string (optional)
# REDIS_URL=redis://localhost:6379  # Default: "redis://localhost:6379" — used for job queue, caching, rate limiting
# GITHUB_TOKEN=                    # Default: "" — GitHub PAT for creating feedback issues
# GITHUB_FEEDBACK_REPO=thivian17/LectureLink-2.0  # Default: "thivian17/LectureLink-2.0"

# ----------------------------------------------------------
# Frontend (packages/web) — Required
# Place these in packages/web/.env.local
# ----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ----------------------------------------------------------
# Frontend (packages/web) — Optional
# ----------------------------------------------------------
# NEXT_PUBLIC_API_URL=http://localhost:8000   # FastAPI backend URL (default: http://localhost:8000)
# NEXT_PUBLIC_USE_MOCKS=false                 # Set to "true" to use mock API responses
