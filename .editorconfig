# https://editorconfig.org
root = true

# Default for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Python
[*.py]
indent_size = 4
max_line_length = 100

# TypeScript / JavaScript / React
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2

# JSON
[*.json]
indent_size = 2

# YAML
[*.{yml,yaml}]
indent_size = 2

# TOML
[*.toml]
indent_size = 4

# CSS / SCSS
[*.{css,scss}]
indent_size = 2

# HTML
[*.html]
indent_size = 2

# Markdown
[*.md]
indent_size = 2
trim_trailing_whitespace = false

# Dockerfiles
[Dockerfile*]
indent_size = 4

# Shell scripts
[*.sh]
indent_size = 2

# Makefiles require tabs
[Makefile]
indent_style = tab

# package.json / lock files
[{package.json,package-lock.json}]
indent_size = 2

# .env files
[.env*]
insert_final_newline = true
